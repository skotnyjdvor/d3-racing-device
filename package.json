{
  "name": "d3-racing-device",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite --host 127.0.0.1 --port 4173",
    "start:server": "node server/api.mjs",
    "test": "node --test",
    "build": "vite build",
    "ios:add": "npm run build && cap add ios && node scripts/configure-ios.mjs",
    "ios:sync": "npm run build && cap sync ios && node scripts/configure-ios.mjs",
    "ios:open": "cap open ios"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "vite": "^7.0.0"
  }
}
